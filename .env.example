# Copy this file to .env and fill in the values.
# Never commit .env — it's gitignored.

# ─── Database ───
# When running via docker-compose, this points at the local container.
DATABASE_URL=postgresql+psycopg://elrom:elrom@localhost:5433/elrom

# ─── LLM (Anthropic Claude) ───
# Used for: answer generation (Sonnet), metadata extraction (Haiku)
ANTHROPIC_API_KEY=

# ─── Embeddings ───
# Primary embedding provider for MVP. Free tier covers the benchmark.
COHERE_API_KEY=

# Used during Week 1 benchmark (and possibly long-term). Pre-paid balance is fine.
OPENAI_API_KEY=

# Which embedding provider to use (cohere | openai)
EMBEDDING_PROVIDER=cohere

# Cohere model
COHERE_EMBED_MODEL=embed-multilingual-v3.0

# OpenAI model (used if EMBEDDING_PROVIDER=openai)
OPENAI_EMBED_MODEL=text-embedding-3-large

# ─── Claude models ───
CLAUDE_ANSWER_MODEL=claude-sonnet-4-6
CLAUDE_EXTRACT_MODEL=claude-haiku-4-5-20251001

# ─── Auth ───
# Used to sign session JWTs. Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=

# Resend API key for magic-link emails (free tier — 100 emails/day)
RESEND_API_KEY=
MAGIC_LINK_FROM_EMAIL=noreply@elrom.tv

# ─── App config ───
APP_ENV=development
LOG_LEVEL=INFO

# Frontend URL (for CORS + magic-link links)
FRONTEND_URL=http://localhost:5173

# Backend URL (for the frontend)
VITE_API_BASE_URL=http://localhost:8000
